---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  active?: string;
}
const { title, description = "Lake's Studio", active = '' } = Astro.props;

const signalColor = (() => {
  if (['recording', 'production', 'mixing'].includes(active)) return 'blue';
  if (['rack', 'front-panels', 'sound-design', 'tools'].includes(active)) return 'amber';
  if (['songs', 'how-it-works'].includes(active)) return 'green';
  if (active === 'blog') return 'red';
  return 'default';
})();

const sections = [
  { num: '01', label: 'Signal Flow', items: [
    { num: '1.1', label: 'Recording',    href: '/recording',    id: 'recording' },
    { num: '1.2', label: 'Production',   href: '/production',   id: 'production' },
    { num: '1.3', label: 'Mixing',       href: '/mixing',       id: 'mixing' },
    { num: '1.4', label: 'Routing',      href: '/routing',      id: 'routing' },
  ]},
  { num: '02', label: 'Gear', items: [
    { num: '2.1', label: 'HA73-EQX2',       href: '/ha73',         id: 'rack' },
    { num: '2.2', label: 'WA76-D2',         href: '/wa76',         id: 'front-panels' },
    { num: '2.3', label: 'Distressor',      href: '/distressor',   id: 'sound-design' },
    { num: '2.4', label: 'Audioscape Opto', href: '/opto',         id: 'tools' },
  ]},
  { num: '03', label: 'Sessions', items: [
    { num: '3.1', label: 'Tracking',     href: '/recording',    id: 'tracking' },
    { num: '3.2', label: 'Mix Pass',     href: '/mixing',       id: 'mixing-proc' },
    { num: '3.3', label: 'Re-amping',    href: '/sound-design', id: 'reamp' },
    { num: '3.4', label: 'Calibration',  href: '/tools',        id: 'calibration' },
    { num: '3.5', label: 'Songs',        href: '/songs',        id: 'songs' },
    { num: '3.6', label: 'How It Works', href: '/how-it-works', id: 'how-it-works' },
  ]},
  { num: '04', label: 'Blog', items: [
    { num: '',    label: 'Session Notes', href: '/blog',         id: 'blog' },
  ]},
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Lake's Studio</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="alternate" type="application/rss+xml" title="Lake's Studio" href="/rss.xml" />
</head>
<body>
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
    <span></span>
  </button>
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <div class="site-layout">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__header">
        <a href="/" class="sidebar__title">Lake's Studio</a>
        <div class="sidebar__subtitle">Technical Reference</div>
      </div>

      <nav class="sidebar__nav">
        {sections.map(section => (
          <div class="sidebar__section">
            <div class="sidebar__section-label">
              <span class="sidebar__section-num">{section.num}</span>
              <span class="sidebar__section-text">{section.label}</span>
            </div>
            <ul class="sidebar__items">
              {section.items.map(item => (
                <li class:list={['sidebar__item', { active: active === item.id }]}>
                  <a href={item.href}>
                    <span class="num">{item.num}</span>
                    <span class="label">{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <div class="sidebar__footer">
        <div class="sidebar__footer-text">
          Wing Rack &middot; 192.168.2.2<br />
          Lake's Studio
        </div>
      </div>
    </aside>

    <main class="content-area">
      <div class={`signal-strip signal-strip--${signalColor}`}></div>
      <div class="content-body">
        <slot />
      </div>
    </main>
  </div>

  <script>
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    toggle?.addEventListener('click', () => {
      sidebar?.classList.toggle('open');
      overlay?.classList.toggle('open');
    });
    overlay?.addEventListener('click', () => {
      sidebar?.classList.remove('open');
      overlay?.classList.remove('open');
    });
  </script>
</body>
</html>
