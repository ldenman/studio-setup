---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  active?: string;
}
const { title, description = "Lake's Studio", active = '' } = Astro.props;

const recentPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const signalColor = (() => {
  if (['signal-flow', 'recording', 'production', 'mixing', 'routing'].includes(active)) return 'blue';
  if (['gear', 'rack', 'ha73', 'wa76', 'distressor', 'opto', 'sound-design'].includes(active)) return 'amber';
  if (['sessions', 'songs', 'how-it-works', 'tools'].includes(active)) return 'green';
  if (active === 'blog') return 'red';
  return 'default';
})();

const sections = [
  { num: '01', label: 'Signal Flow', href: '/signal-flow', items: [
    { num: '1.1', label: 'Recording',    href: '/recording',    id: 'recording' },
    { num: '1.2', label: 'Production',   href: '/production',   id: 'production' },
    { num: '1.3', label: 'Mixing',       href: '/mixing',       id: 'mixing' },
    { num: '1.4', label: 'Routing',      href: '/routing',      id: 'routing' },
  ]},
  { num: '02', label: 'Gear', href: '/gear', items: [
    { num: '2.1', label: 'HA73-EQX2',       href: '/ha73',         id: 'ha73' },
    { num: '2.2', label: 'WA76-D2',         href: '/wa76',         id: 'wa76' },
    { num: '2.3', label: 'Distressor',      href: '/distressor',   id: 'distressor' },
    { num: '2.4', label: 'Audioscape Opto', href: '/opto',         id: 'opto' },
    { num: '2.5', label: 'Rack Room',       href: '/rack',         id: 'rack' },
    { num: '2.6', label: 'Sound Design',    href: '/sound-design', id: 'sound-design' },
  ]},
  { num: '03', label: 'Sessions', href: '/sessions', items: [
    { num: '3.1', label: 'Songs',        href: '/songs',        id: 'songs' },
    { num: '3.2', label: 'How It Works', href: '/how-it-works', id: 'how-it-works' },
    { num: '3.3', label: 'Tools',        href: '/tools',        id: 'tools' },
  ]},
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Lake's Studio</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="alternate" type="application/rss+xml" title="Lake's Studio" href="/rss.xml" />
</head>
<body>
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
    <span></span>
  </button>
  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <div class="site-layout">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__header">
        <a href="/" class="sidebar__title">Lake's Studio</a>
        <div class="sidebar__subtitle">Technical Reference</div>
      </div>

      <nav class="sidebar__nav">
        {sections.map(section => (
          <div class="sidebar__section">
            <div class="sidebar__section-label">
              <span class="sidebar__section-num">{section.num}</span>
              {section.href
                ? <a href={section.href} class="sidebar__section-text">{section.label}</a>
                : <span class="sidebar__section-text">{section.label}</span>
              }
            </div>
            <ul class="sidebar__items">
              {section.items.map(item => (
                <li class:list={['sidebar__item', { active: active === item.id }]}>
                  <a href={item.href}>
                    <span class="num">{item.num}</span>
                    <span class="label">{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <div class="sidebar__section">
          <div class="sidebar__section-label">
            <span class="sidebar__section-num">04</span>
            <a href="/blog" class="sidebar__section-text">Blog</a>
          </div>
          <ul class="sidebar__items">
            {recentPosts.map(post => (
              <li class:list={['sidebar__item', { active: active === 'blog' && title === post.data.title }]}>
                <a href={`/blog/${post.id}`}>
                  <span class="num"></span>
                  <span class="label">{post.data.title}</span>
                </a>
              </li>
            ))}
            <li class="sidebar__item sidebar__item--more">
              <a href="/blog">
                <span class="num"></span>
                <span class="label">All posts &rarr;</span>
              </a>
            </li>
          </ul>
        </div>
      </nav>

      <div class="sidebar__footer">
        <div class="sidebar__footer-text">
          Wing Rack &middot; 192.168.2.2<br />
          Lake's Studio
        </div>
      </div>
    </aside>

    <main class="content-area">
      <div class={`signal-strip signal-strip--${signalColor}`}></div>
      <div class="content-body">
        <slot />
      </div>
    </main>
  </div>

  <script>
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    toggle?.addEventListener('click', () => {
      sidebar?.classList.toggle('open');
      overlay?.classList.toggle('open');
    });
    overlay?.addEventListener('click', () => {
      sidebar?.classList.remove('open');
      overlay?.classList.remove('open');
    });

    // ── SVG breathing (non-blog pages) ──
    (function() {
      if (document.getElementById('article-body')) return;

      const bTargets = [];
      const cTargets = [];
      const wiggleTargets = [];
      const knobTargets = [];

      function hexToHSL(hex) {
        hex = hex.replace('#', '');
        if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
        const r = parseInt(hex.substring(0,2), 16) / 255;
        const g = parseInt(hex.substring(2,4), 16) / 255;
        const b = parseInt(hex.substring(4,6), 16) / 255;
        const max = Math.max(r, g, b), min = Math.min(r, g, b);
        let h, s, l = (max + min) / 2;
        if (max === min) { h = s = 0; }
        else {
          const d = max - min;
          s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
          if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
          else if (max === g) h = ((b - r) / d + 2) / 6;
          else h = ((r - g) / d + 4) / 6;
        }
        return [h * 360, s * 100, l * 100];
      }

      function hslToStr(h, s, l) {
        return 'hsl(' + h.toFixed(1) + ', ' + s.toFixed(1) + '%, ' + l.toFixed(1) + '%)';
      }

      function addColorShift(el, attr) {
        const val = el.getAttribute(attr);
        if (!val || val === 'none' || !val.startsWith('#') || val.length < 4) return;
        const [h, s, l] = hexToHSL(val);
        if (s < 3) {
          cTargets.push({ el, attr, h: h || 30, s: 0, l, hueAmount: 60 + Math.random() * 40, satAmount: 8 + Math.random() * 6, speed: 0.06 + Math.random() * 0.06, offset: Math.random() * Math.PI * 2 });
        } else {
          cTargets.push({ el, attr, h, s, l, hueAmount: 45 + Math.random() * 30, speed: 0.06 + Math.random() * 0.06, offset: Math.random() * Math.PI * 2 });
        }
      }

      document.querySelectorAll('.content-body svg').forEach(svg => {
        const all = Array.from(svg.querySelectorAll('*'));
        for (const el of all) {
          const tag = el.tagName.toLowerCase();
          if (['defs','lineargradient','radialgradient','stop','filter','svg','g','animate','text'].includes(tag)) continue;
          addColorShift(el, 'fill');
          addColorShift(el, 'stroke');
          const s = 0.25 + Math.random() * 0.25, p = Math.random() * Math.PI * 2;
          if (tag === 'circle') {
            const r = parseFloat(el.getAttribute('r'));
            if (r > 0) bTargets.push({ el, attr: 'r', base: r, amount: r * 0.15, speed: s, offset: p });
          } else if (tag === 'ellipse') {
            const rx = parseFloat(el.getAttribute('rx'));
            const ry = parseFloat(el.getAttribute('ry'));
            if (rx > 0) bTargets.push({ el, attr: 'rx', base: rx, amount: rx * 0.15, speed: s, offset: p });
            if (ry > 0) bTargets.push({ el, attr: 'ry', base: ry, amount: ry * 0.15, speed: s, offset: p });
          } else if (tag === 'rect') {
            const w = parseFloat(el.getAttribute('width')), h = parseFloat(el.getAttribute('height'));
            if (w >= 800 && h >= 200) continue;
            if (w <= 10 || h <= 10) continue;
            const x = parseFloat(el.getAttribute('x'));
            const y = parseFloat(el.getAttribute('y'));
            const stroke = el.getAttribute('stroke');
            const strokeW = el.getAttribute('stroke-width') || '1';
            const fill = el.getAttribute('fill') || 'none';
            const op = el.getAttribute('opacity');

            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            if (stroke) path.setAttribute('stroke', stroke);
            path.setAttribute('stroke-width', strokeW);
            path.setAttribute('fill', fill);
            if (op) path.setAttribute('opacity', op);
            const ix = x || 0, iy = y || 0;
            const rr = parseFloat(el.getAttribute('rx') || '0');
            if (rr > 0) {
              path.setAttribute('d', `M ${ix+rr} ${iy} L ${ix+w-rr} ${iy} A ${rr} ${rr} 0 0 1 ${ix+w} ${iy+rr} L ${ix+w} ${iy+h-rr} A ${rr} ${rr} 0 0 1 ${ix+w-rr} ${iy+h} L ${ix+rr} ${iy+h} A ${rr} ${rr} 0 0 1 ${ix} ${iy+h-rr} L ${ix} ${iy+rr} A ${rr} ${rr} 0 0 1 ${ix+rr} ${iy} Z`);
            } else {
              path.setAttribute('d', `M ${ix} ${iy} L ${ix+w} ${iy} L ${ix+w} ${iy+h} L ${ix} ${iy+h} Z`);
            }
            el.parentNode.replaceChild(path, el);

            addColorShift(path, 'stroke');
            addColorShift(path, 'fill');

            const topSegs = Math.max(8, Math.floor(w / 5));
            const sideSegs = Math.max(8, Math.floor(h / 5));
            const isLarge = (w >= 200 || h >= 100);

            wiggleTargets.push({
              path, rectX: ix, rectY: iy, rectW: w, rectH: h, rr: rr,
              topSegs, sideSegs,
              speed: 0.3 + Math.random() * 0.3,
              amplitude: 0.5 + Math.random() * 0.3,
              phase: p,
              waveFreq: 1 + Math.random() * 0.8,
              isRect: true,
              noBreathe: isLarge
            });
          } else if (tag === 'line') {
            const x1 = parseFloat(el.getAttribute('x1'));
            const y1 = parseFloat(el.getAttribute('y1'));
            const x2 = parseFloat(el.getAttribute('x2'));
            const y2 = parseFloat(el.getAttribute('y2'));
            const cap = el.getAttribute('stroke-linecap');
            const dx = x2 - x1, dy = y2 - y1;
            const len = Math.sqrt(dx * dx + dy * dy);

            // Knob pointer: round cap, short line (~10-22px)
            if (cap === 'round' && len > 8 && len < 100) {
              const baseAngle = Math.atan2(dy, dx);
              knobTargets.push({
                el, cx: x1, cy: y1, radius: len,
                baseAngle: baseAngle,
                swingAmount: 0.8 + Math.random() * 0.5,
                speed: 0.3 + Math.random() * 0.2,
                offset: p
              });
            } else {
              const sw = parseFloat(el.getAttribute('stroke-width') || '1');
              const op = parseFloat(el.getAttribute('opacity') || '1');
              bTargets.push({ el, attr: 'stroke-width', base: sw, amount: sw * 0.4, speed: s, offset: p });
              bTargets.push({ el, attr: 'opacity', base: op, amount: op * 0.15, speed: s * 0.7, offset: p });
            }
          } else if (tag === 'path') {
            const sw = parseFloat(el.getAttribute('stroke-width') || '0');
            if (sw > 0) bTargets.push({ el, attr: 'stroke-width', base: sw, amount: Math.max(0.5, sw * 0.5), speed: s, offset: p });
            const op = parseFloat(el.getAttribute('opacity') || '1');
            bTargets.push({ el, attr: 'opacity', base: op, amount: op * 0.15, speed: s * 0.7, offset: p });
            // Path wiggle
            const d = el.getAttribute('d') || '';
            if (d && sw > 0) {
              const nums = d.match(/-?\d+\.?\d*/g);
              if (nums && nums.length >= 4) {
                wiggleTargets.push({ path: el, baseD: d, nums: nums.map(Number), speed: 0.5 + Math.random() * 0.5, amplitude: 3 + Math.random() * 2, phase: p, isPath: true });
              }
            }
          } else if (tag === 'polygon') {
            const op = parseFloat(el.getAttribute('opacity') || '1');
            bTargets.push({ el, attr: 'opacity', base: op, amount: op * 0.15, speed: s, offset: p });
          }
        }
      });

      console.log('GLOBAL BREATHE:', bTargets.length, 'b', cTargets.length, 'c', wiggleTargets.length, 'w', knobTargets.length, 'knobs');
      if (bTargets.length === 0 && cTargets.length === 0 && wiggleTargets.length === 0 && knobTargets.length === 0) return;

      // Catmull-Rom spline: takes array of {x,y} points (closed loop),
      // returns SVG path with smooth C curves through every point.
      function smoothClosedPath(pts) {
        const n = pts.length;
        if (n < 3) return '';
        let d = 'M ' + pts[0].x.toFixed(1) + ' ' + pts[0].y.toFixed(1);
        for (let i = 0; i < n; i++) {
          const p0 = pts[(i - 1 + n) % n];
          const p1 = pts[i];
          const p2 = pts[(i + 1) % n];
          const p3 = pts[(i + 2) % n];
          // Catmull-Rom to cubic bezier control points
          const cp1x = p1.x + (p2.x - p0.x) / 6;
          const cp1y = p1.y + (p2.y - p0.y) / 6;
          const cp2x = p2.x - (p3.x - p1.x) / 6;
          const cp2y = p2.y - (p3.y - p1.y) / 6;
          d += ' C ' + cp1x.toFixed(1) + ' ' + cp1y.toFixed(1) + ', '
             + cp2x.toFixed(1) + ' ' + cp2y.toFixed(1) + ', '
             + p2.x.toFixed(1) + ' ' + p2.y.toFixed(1);
        }
        d += ' Z';
        return d;
      }

      function tick(time) {
        const t = time / 1000;
        for (const b of bTargets) {
          const val = b.base + Math.sin(t * b.speed + b.offset) * b.amount;
          b.el.setAttribute(b.attr, String(Math.max(0.1, val)));
        }
        for (const c of cTargets) {
          const hue = c.h + Math.sin(t * c.speed + c.offset) * c.hueAmount;
          const sat = c.s + (c.satAmount ? Math.sin(t * c.speed * 0.7 + c.offset) * c.satAmount : 0);
          c.el.setAttribute(c.attr, hslToStr(hue, Math.max(0, sat), c.l));
        }
        for (const w of wiggleTargets) {
          if (w.isRect) {
            const amp = Math.sin(t * 0.5 + w.phase) * w.amplitude;
            const breatheAmt = w.noBreathe ? 0 : Math.sin(t * 0.15 + w.phase) * 0.12;
            const dw = w.rectW * breatheAmt, dh = w.rectH * breatheAmt;
            const bx = w.rectX - dw/2, by = w.rectY - dh/2;
            const bw = w.rectW + dw, bh = w.rectH + dh;
            const pts = [];
            const segs = w.topSegs;
            // Top edge (left to right) — wiggle perpendicular (Y)
            for (let i = 0; i <= segs; i++) {
              const f = i / segs;
              const wave = Math.sin(f * w.waveFreq * Math.PI * 2 + t * w.speed) * amp;
              pts.push({ x: bx + bw * f, y: by + wave });
            }
            // Right edge (top to bottom) — wiggle perpendicular (X)
            for (let i = 1; i <= w.sideSegs; i++) {
              const f = i / w.sideSegs;
              const wave = Math.sin(f * w.waveFreq * Math.PI * 2 + t * w.speed + 1.5) * amp;
              pts.push({ x: bx + bw + wave, y: by + bh * f });
            }
            // Bottom edge (right to left) — wiggle perpendicular (Y)
            for (let i = 1; i <= segs; i++) {
              const f = i / segs;
              const wave = Math.sin(f * w.waveFreq * Math.PI * 2 + t * w.speed + 3) * amp;
              pts.push({ x: bx + bw * (1 - f), y: by + bh + wave });
            }
            // Left edge (bottom to top) — wiggle perpendicular (X)
            for (let i = 1; i <= w.sideSegs; i++) {
              const f = i / w.sideSegs;
              const wave = Math.sin(f * w.waveFreq * Math.PI * 2 + t * w.speed + 4.5) * amp;
              pts.push({ x: bx + wave, y: by + bh * (1 - f) });
            }
            w.path.setAttribute('d', smoothClosedPath(pts));
          } else {
            const amp = Math.sin(t * 0.3 + w.phase) * w.amplitude;
            let ni = 0;
            const newD = w.baseD.replace(/-?\d+\.?\d*/g, function() {
              const orig = w.nums[ni];
              const wiggle = Math.sin(t * w.speed + ni * 0.7 + w.phase) * amp;
              ni++;
              return (orig + wiggle).toFixed(1);
            });
            w.path.setAttribute('d', newD);
          }
        }
        for (const k of knobTargets) {
          const angle = k.baseAngle + Math.sin(t * k.speed + k.offset) * k.swingAmount;
          k.el.setAttribute('x2', String(k.cx + Math.cos(angle) * k.radius));
          k.el.setAttribute('y2', String(k.cy + Math.sin(angle) * k.radius));
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    })();
  </script>
</body>
</html>
