            <!-- Divider label: Recorded -->
            <text x="590" y="36" text-anchor="end" font-family="var(--mono)" font-size="7" fill="var(--stone)" letter-spacing="1">RECORDED</text>

            <!-- Track 1: Vocal -->
            <rect x="100" y="42" width="500" height="28" rx="2" fill="var(--vocal-blue)" opacity="0.1" stroke="var(--vocal-blue)" stroke-width="1" opacity="0.3"/>
            <text x="112" y="60" font-family="var(--mono)" font-size="9" font-weight="500" fill="var(--vocal-blue)">Vocal</text>
            <g opacity="0.4">
              <rect x="180" y="48" width="2" height="16" rx="1" fill="var(--vocal-blue)"/>
              <rect x="186" y="46" width="2" height="20" rx="1" fill="var(--vocal-blue)"/>
              <rect x="192" y="50" width="2" height="12" rx="1" fill="var(--vocal-blue)"/>
              <rect x="198" y="46" width="2" height="20" rx="1" fill="var(--vocal-blue)"/>
              <rect x="204" y="48" width="2" height="16" rx="1" fill="var(--vocal-blue)"/>
              <rect x="220" y="46" width="2" height="20" rx="1" fill="var(--vocal-blue)"/>
              <rect x="226" y="50" width="2" height="12" rx="1" fill="var(--vocal-blue)"/>
              <rect x="232" y="46" width="2" height="20" rx="1" fill="var(--vocal-blue)"/>
