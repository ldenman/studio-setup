              <line x1="-70" y1="20" x2="70" y2="20" stroke="var(--session-green)" stroke-width="0.5" opacity="0.3"/>
              <text x="0" y="14" text-anchor="middle" font-family="var(--mono)" font-size="9" font-weight="600" fill="var(--session-green)">Session Lessons</text>
