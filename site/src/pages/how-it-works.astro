              <text x="0" y="52" text-anchor="middle" font-family="var(--body)" font-size="10" fill="var(--slate)">Every mistake made and</text>
              <text x="0" y="66" text-anchor="middle" font-family="var(--body)" font-size="10" fill="var(--slate)">fixed, never repeated.</text>
            </g>

            <!-- Document 4: Blog (bottom right) -->
            <g transform="translate(600, 160)">
              <rect x="-70" y="0" width="140" height="80" rx="2" fill="var(--white)" stroke="var(--tape-coral)" stroke-width="1.5"/>
