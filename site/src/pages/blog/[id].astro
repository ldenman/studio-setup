---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} active="blog">
  <div class="container">
    <section class="page-header">
      <a href="/blog" style="font-size:12px;color:var(--stone);letter-spacing:1px;text-transform:uppercase">&larr; All Posts</a>
    </section>

    <article class="article">
      <h1>{post.data.title}</h1>
      <div class="article__meta">
        {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        {post.data.tags && (
          <span style="margin-left:16px">
            {post.data.tags.map(tag => <a href={`/blog/tag/${tag}`} class="tag" style="margin-left:4px">{tag}</a>)}
          </span>
        )}
      </div>
      {post.data.hero && (
        <img src={post.data.hero} alt="" role="presentation" style="width:100%;max-width:680px;height:auto;border-radius:2px;margin-bottom:32px;border:1px solid var(--linen)" />
      )}
      <div class="article__body">
        <Content />
      </div>
    </article>
  </div>
</Base>
