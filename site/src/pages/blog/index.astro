---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = allPosts.filter(post => !post.data.draft);
const showDrafts = import.meta.env.PUBLIC_SHOW_DRAFTS === 'true';
---

<Base title="Blog" active="blog">
  <div class="container">

    <section class="page-header">
      <h3>From the Studio</h3>
      <h1>Blog</h1>
      <p>Session notes, gear discoveries, routing adventures, and the occasional existential crisis about gain staging.</p>
      {showDrafts && <p><a href="/blog/drafts" style="color: var(--amber, #d4a574);">View drafts</a></p>}
    </section>

    <div class="vu-bar"></div>

    <section>
      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <span class="post-date">{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            <div>
              <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map(tag => <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>)}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

  </div>
</Base>
