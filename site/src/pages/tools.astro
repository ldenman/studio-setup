---
import Base from '../layouts/Base.astro';
---

<Base title="Tools" active="tools">
  <div class="container">

    <section class="page-header">
      <h3>Utilities</h3>
      <h1>Tools</h1>
      <p>Quick-reference tools for sessions. BPM calculator for syncing delays, Wing color map for channel organization.</p>
    </section>

    <div class="vu-bar"></div>

    <section>
      <h3>BPM &rarr; Delay Calculator</h3>
      <div class="prose mt-sm">
        <p>Enter a tempo to calculate delay times for common note values. Use these to sync the Wing's delay effects to the song.</p>
      </div>
      <div class="mt-md" style="display:flex;align-items:center;gap:16px">
        <span class="text-dim" style="font-size:12px">BPM</span>
        <input type="number" class="bpm-input" id="bpm-input" value="120" min="40" max="300">
      </div>
      <div class="bpm-grid" id="bpm-grid">
        <div class="bpm-cell"><div class="bpm-cell__val" id="v-quarter">500</div><div class="bpm-cell__label">1/4 note</div></div>
        <div class="bpm-cell"><div class="bpm-cell__val" id="v-dotted8">375</div><div class="bpm-cell__label">Dotted 1/8</div></div>
        <div class="bpm-cell"><div class="bpm-cell__val" id="v-eighth">250</div><div class="bpm-cell__label">1/8 note</div></div>
        <div class="bpm-cell"><div class="bpm-cell__val" id="v-sixteenth">125</div><div class="bpm-cell__label">1/16 note</div></div>
        <div class="bpm-cell"><div class="bpm-cell__val" id="v-triplet">333</div><div class="bpm-cell__label">1/4 triplet</div></div>
        <div class="bpm-cell"><div class="bpm-cell__val" id="v-mod">2.00</div><div class="bpm-cell__label">1/4 Hz (mod)</div></div>
      </div>
    </section>

    <section>
      <h3>Wing Color Map</h3>
      <div class="prose mt-sm">
        <p>Channel colors on the Wing correspond to signal type. Blue for vocals, red for guitar, green for session players, coral for tape returns, orange for the mix bus.</p>
      </div>
      <div class="color-grid mt-md">
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#7088a0"></div>1 Gray Blue</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#4a90d9"></div>2 Medium Blue</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#2c3e6e"></div>3 Dark Blue</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#1abc9c"></div>4 Turquoise</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#27ae60"></div>5 Green</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#6b8e23"></div>6 Olive Green</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#f1c40f"></div>7 Yellow</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#e67e22"></div>8 Orange</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#c0392b"></div>9 Red</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#e8a090"></div>10 Coral</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#e07098"></div>11 Pink</div>
        <div class="color-swatch"><div class="color-swatch__dot" style="background:#9b59b6"></div>12 Mauve</div>
      </div>
    </section>

    <section>
      <h3>Automation</h3>
      <div class="prose mt-sm">
        <p>
          The entire mixer is programmable. Every fader, mute, effect, and routing decision can be scripted, so sessions start the same way every time. A custom control tool reads and writes any parameter on the console, and startup scripts handle all the repetitive setup automatically.
        </p>
      </div>
    </section>

  </div>

  <script>
    const bpmInput = document.getElementById('bpm-input');
    function update() {
      const bpm = parseFloat(bpmInput?.value || '120') || 120;
      const q = 60000 / bpm;
      const el = (id: string) => document.getElementById(id);
      el('v-quarter')!.textContent = Math.round(q).toString();
      el('v-dotted8')!.textContent = Math.round(q * 0.75).toString();
      el('v-eighth')!.textContent = Math.round(q / 2).toString();
      el('v-sixteenth')!.textContent = Math.round(q / 4).toString();
      el('v-triplet')!.textContent = Math.round(q * 2 / 3).toString();
      el('v-mod')!.textContent = (bpm / 60).toFixed(2);
    }
    bpmInput?.addEventListener('input', update);
  </script>
</Base>
