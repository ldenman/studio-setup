---
import Base from '../layouts/Base.astro';
---
<Base title="Distressor EL8" active="sound-design">
  <section class="page-header">
    <span class="chapter-label">02 — Gear</span>
    <h1>Distressor EL8</h1>
    <p>Empirical Labs. Eight ratios, three flavors of distortion, one knob away from chaos.</p>
  </section>

