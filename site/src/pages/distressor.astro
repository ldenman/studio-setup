        <rect x="4" y="40" width="16" height="4" rx="1" fill="#5a5" opacity="0.8"/>
        <rect x="4" y="46" width="16" height="4" rx="1" fill="#5a5" opacity="0.9"/>
        <rect x="4" y="52" width="16" height="4" rx="1" fill="#5a5"/>
