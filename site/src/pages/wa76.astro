          <text x="11" y="10" text-anchor="middle" font-family="var(--font-mono)" font-size="6" fill="#fff">4</text>
          <rect x="26" y="0" width="22" height="14" rx="2" fill="#222" stroke="#555" stroke-width="0.8"/>
          <text x="37" y="10" text-anchor="middle" font-family="var(--font-mono)" font-size="6" fill="#fff">8</text>
