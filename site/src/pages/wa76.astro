---
import Base from '../layouts/Base.astro';
---
<Base title="WA76-D2" active="wa76">
  <section class="page-header">
    <span class="chapter-label">02 — Gear</span>
    <h1>WA76-D2</h1>
    <p>Dual-channel 1176 compressor. Fast transients, unmistakable color.</p>
