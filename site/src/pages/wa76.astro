        <line x1="600" y1="58" x2="594" y2="44" stroke="#222" stroke-width="1.5" stroke-linecap="round"/>
        <text x="600" y="84" text-anchor="middle" font-family="var(--font-mono)" font-size="6" fill="#888">ATTACK</text>

