---
import Base from '../layouts/Base.astro';
---

<Base title="Front Panels" active="">
  <div style="max-width:1500px;margin:0 auto;padding:0 16px">
    <section class="page-header">
      <h3>Calibrated Settings</h3>
      <h1>Front Panels</h1>
      <p>Outboard gear with dials set to calibrated positions. Reference for every session.</p>
    </section>
  </div>

  <div id="panels">
    <div class="info" id="info">Hover over any control</div>
    <svg id="svg" viewBox="0 0 1400 400" preserveAspectRatio="xMidYMid meet"></svg>
  </div>

  <style>
    #panels { max-width: 1400px; margin: 0 auto; padding: 0 8px 80px; }
    .info {
      font-family: var(--mono); font-size: 11px; color: var(--stone);
      padding: 8px 14px; margin-bottom: 4px;
      background: var(--soot); border: 1px solid var(--smoke); border-radius: 2px;
    }
    #svg { display: block; width: 100%; background: #060608; border: 1px solid #1a1a18; border-radius: 2px; }
  </style>

  <script>
    const svg = document.getElementById('svg')!;
    const info = document.getElementById('info')!;

    // ════════════════════════════════════════════════
    // HERITAGE AUDIO HA73-EQX2 — NEVE 1073 CLONE
    // Channel A (Vocal Chain) — Calibrated
    //
    // Physical reference: 2U, dark grey/charcoal faceplate
    // Classic 1073 layout: DI → preamp gain (red) →
    //   output attenuator (stepped) → EQ section →
    //   HPF → switches
    //
    // EQ: 3-band Neve style with stepped frequency selectors
    //   HIGH: 12kHz shelf, gain ±16dB
    //   MID: 7.2k/4.8k/3.2k/1.6k/0.7k/0.36k peak, gain ±16dB
    //   LOW: 220/110/60/35 Hz shelf, gain ±16dB
    //   HPF: 300/160/80/50 Hz, 18dB/oct
    //
    // Calibrated: Gain 35, Output 1 o'clock, EQ flat/bypassed
    // ════════════════════════════════════════════════

    const PX = 30;   // Panel x
    const PY = 30;   // Panel y
    const PW = 1340; // Panel width
    const PH = 340;  // Panel height (2U)

    // Neve faceplate colors
    const FACEPLATE = '#2a2a2d';      // Dark charcoal grey
    const FACEPLATE_EDGE = '#3a3a3d';
    const NEVE_TEXT = '#c0c0b8';      // Cream/silver text
    const NEVE_DIM = '#666660';       // Dim markings
    const RED_KNOB = '#8b1a1a';       // Heritage red gain knob
    const RED_KNOB_EDGE = '#a52a2a';
    const SILVER_KNOB = '#555558';    // Silver/grey pointer knobs
    const SILVER_EDGE = '#6a6a6d';
    const BLACK_KNOB = '#1a1a1c';     // Black selector knobs
    const BLACK_EDGE = '#2a2a2d';
    const INDICATOR = '#e8e8d8';      // White indicator line
    const VOCAL_HL = '#6a9ab8';       // Vocal chain highlight

    let s = '';

    // ── FACEPLATE ──
    // Dark charcoal with subtle horizontal brushed texture
    s += `<rect x="${PX}" y="${PY}" width="${PW}" height="${PH}" rx="4" fill="${FACEPLATE}" stroke="${FACEPLATE_EDGE}" stroke-width="2"/>`;
    // Brushed metal texture
    for (let i = 0; i < PH; i += 1.5) {
      const op = 0.03 + Math.random() * 0.04;
      s += `<line x1="${PX}" y1="${PY + i}" x2="${PX + PW}" y2="${PY + i}" stroke="#222225" stroke-width="0.5" opacity="${op}"/>`;
    }

    // Rack screws (hex style, 4 corners + middle)
    const screwPositions = [
      [PX + 14, PY + 14], [PX + PW - 14, PY + 14],
      [PX + 14, PY + PH - 14], [PX + PW - 14, PY + PH - 14],
      [PX + 14, PY + PH/2], [PX + PW - 14, PY + PH/2],
    ];
    screwPositions.forEach(([sx, sy]) => {
      s += `<circle cx="${sx}" cy="${sy}" r="6" fill="#1a1a1c" stroke="#333336" stroke-width="1"/>`;
      // Hex pattern
      for (let a = 0; a < 6; a++) {
        const angle = a * 60 * Math.PI / 180;
        const x1 = sx + Math.cos(angle) * 3;
        const y1 = sy + Math.sin(angle) * 3;
        const x2 = sx + Math.cos(angle + Math.PI/3) * 3;
        const y2 = sy + Math.sin(angle + Math.PI/3) * 3;
        s += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="#444" stroke-width="0.5"/>`;
      }
    });

    // ── BRAND / MODEL TEXT ──
    s += `<text x="${PX + 50}" y="${PY + 30}" fill="${NEVE_TEXT}" font-family="DM Serif Display,serif" font-size="16" opacity="0.7">Heritage Audio</text>`;
    s += `<text x="${PX + 50}" y="${PY + 48}" fill="${NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="9" letter-spacing="2">HA-73 EQX2 ELITE</text>`;
    s += `<text x="${PX + PW - 50}" y="${PY + 30}" text-anchor="end" fill="${VOCAL_HL}" font-family="JetBrains Mono,monospace" font-size="9" letter-spacing="2" opacity="0.6">CHANNEL A — VOCAL</text>`;
    s += `<text x="${PX + PW - 50}" y="${PY + 48}" text-anchor="end" fill="${NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="8">Calibrated: 1kHz @ -18dBFS → 2 yellow on Ch17</text>`;

    // ── HELPER: Neve-style stepped rotary knob ──
    function neveKnob(cx: number, cy: number, r: number, value: number, min: number, max: number,
      label: string, valLabel: string, style: 'red'|'silver'|'black', positions: string[], note: string,
      rotation?: 'standard'|'clock'): string {
      let k = '';
      const pct = (value - min) / (max - min);
      const rot = rotation || 'clock';
      // 'standard': min at bottom-left (-135°), max at bottom-right (+135°) — for gain knobs
      // 'clock': min at 7 o'clock (120°), max at 5 o'clock (420°) — 12 o'clock = center
      const startAngle = rot === 'standard' ? -135 : 120;
      const sweep = rot === 'standard' ? 270 : 300;
      const angle = startAngle + pct * sweep;

      // Position markings around the knob
      positions.forEach((pos, i) => {
        const t = i / (positions.length - 1);
        const a = (startAngle + t * sweep) * Math.PI / 180;
        const tx = cx + Math.cos(a) * (r + 16);
        const ty = cy + Math.sin(a) * (r + 16);
        const isActive = Math.abs(t - pct) < 0.05;
        k += `<text x="${tx}" y="${ty + 3}" text-anchor="middle" fill="${isActive ? INDICATOR : NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="${pos.length > 2 ? 5 : 6}" opacity="${isActive ? 1 : 0.5}">${pos}</text>`;
      });

      // Knob shadow
      k += `<circle cx="${cx + 1}" cy="${cy + 2}" r="${r + 1}" fill="#0a0a0c" opacity="0.5"/>`;

      // Knob body
      let fillCol: string, strokeCol: string;
      if (style === 'red') {
        fillCol = RED_KNOB; strokeCol = RED_KNOB_EDGE;
        // Gradient effect on red knob
        k += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${fillCol}" stroke="${strokeCol}" stroke-width="2"/>`;
        k += `<circle cx="${cx - r*0.15}" cy="${cy - r*0.15}" r="${r * 0.7}" fill="none" stroke="#a03030" stroke-width="0.5" opacity="0.3"/>`;
      } else if (style === 'silver') {
        fillCol = SILVER_KNOB; strokeCol = SILVER_EDGE;
        k += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${fillCol}" stroke="${strokeCol}" stroke-width="1.5"/>`;
        // Knurled edge texture
        for (let a = 0; a < 360; a += 12) {
          const rad = a * Math.PI / 180;
          const x1 = cx + Math.cos(rad) * (r - 1);
          const y1 = cy + Math.sin(rad) * (r - 1);
          const x2 = cx + Math.cos(rad) * r;
          const y2 = cy + Math.sin(rad) * r;
          k += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="#777" stroke-width="0.5"/>`;
        }
      } else {
        fillCol = BLACK_KNOB; strokeCol = BLACK_EDGE;
        k += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${fillCol}" stroke="${strokeCol}" stroke-width="1.5"/>`;
      }

      // Pointer/indicator line
      const pa = angle * Math.PI / 180;
      const px = cx + Math.cos(pa) * (r * 0.75);
      const py = cy + Math.sin(pa) * (r * 0.75);
      k += `<line x1="${cx}" y1="${cy}" x2="${px}" y2="${py}" stroke="${INDICATOR}" stroke-width="${style === 'red' ? 2.5 : 2}" stroke-linecap="round"/>`;

      // Center cap
      if (style === 'red') {
        k += `<circle cx="${cx}" cy="${cy}" r="3" fill="#6a1515"/>`;
      } else {
        k += `<circle cx="${cx}" cy="${cy}" r="2.5" fill="${fillCol}" stroke="${strokeCol}" stroke-width="0.5"/>`;
      }

      // Label
      k += `<text x="${cx}" y="${cy + r + 28}" text-anchor="middle" fill="${NEVE_TEXT}" font-family="JetBrains Mono,monospace" font-size="8" font-weight="500" letter-spacing="1">${label}</text>`;
      // Value
      k += `<text x="${cx}" y="${cy + r + 40}" text-anchor="middle" fill="${VOCAL_HL}" font-family="JetBrains Mono,monospace" font-size="9" font-weight="600">${valLabel}</text>`;

      // Wrap in interactive group
      return `<g class="ctrl" data-note="${note}" style="cursor:pointer">${k}</g>`;
    }

    // ── HELPER: Toggle switch ──
    function neveSwitch(cx: number, cy: number, label: string, active: boolean, note: string): string {
      let k = '';
      k += `<g class="ctrl" data-note="${note}" style="cursor:pointer">`;
      // Switch housing
      k += `<rect x="${cx - 10}" y="${cy - 14}" width="20" height="28" rx="3" fill="#1a1a1c" stroke="#333" stroke-width="0.8"/>`;
      // Toggle position
      const ty = active ? cy - 6 : cy + 6;
      k += `<rect x="${cx - 6}" y="${ty - 4}" width="12" height="8" rx="2" fill="${active ? '#666' : '#333'}" stroke="#555" stroke-width="0.5"/>`;
      // LED indicator
      if (active) {
        k += `<circle cx="${cx}" cy="${cy - 22}" r="3" fill="#cc3333" opacity="0.9"/>`;
        k += `<circle cx="${cx}" cy="${cy - 22}" r="5" fill="#cc3333" opacity="0.15"/>`;
      }
      // Label
      k += `<text x="${cx}" y="${cy + 26}" text-anchor="middle" fill="${NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="7" letter-spacing="0.5">${label}</text>`;
      k += `</g>`;
      return k;
    }

    // ── HELPER: DI jack ──
    function diJack(cx: number, cy: number): string {
      let k = '';
      k += `<g class="ctrl" data-note="Front panel 1/4 inch DI input — instrument level" style="cursor:pointer">`;
      k += `<circle cx="${cx}" cy="${cy}" r="10" fill="#0e0e10" stroke="#3a3a3d" stroke-width="1.5"/>`;
      k += `<circle cx="${cx}" cy="${cy}" r="4" fill="#080808"/>`;
      k += `<text x="${cx}" y="${cy + 20}" text-anchor="middle" fill="${NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="7">DI</text>`;
      k += `</g>`;
      return k;
    }

    // ── LAYOUT ──
    // Left to right: DI | GAIN (red) | OUTPUT (stepped) | HIGH EQ | MID EQ | LOW EQ | HPF | switches
    // Based on 1073 layout: preamp section left, EQ center-right, switches far right

    const ROW_Y = PY + 190; // Main knob row vertical center

    // Section divider lines
    const sections = [
      { x: PX + 120, label: 'PREAMP' },
      { x: PX + 380, label: 'EQ — HIGH' },
      { x: PX + 560, label: 'EQ — MID' },
      { x: PX + 780, label: 'EQ — LOW' },
      { x: PX + 960, label: 'FILTER' },
      { x: PX + 1100, label: 'SWITCHES' },
    ];
    sections.forEach((sec, i) => {
      s += `<line x1="${sec.x}" y1="${PY + 60}" x2="${sec.x}" y2="${PY + PH - 20}" stroke="#333336" stroke-width="0.5" opacity="0.4"/>`;
      s += `<text x="${sec.x + 8}" y="${PY + 72}" fill="${NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="6" letter-spacing="1.5" opacity="0.6">${sec.label}</text>`;
    });

    // DI input
    s += diJack(PX + 75, ROW_Y);

    // GAIN — large red knob with chrome bezel
    // Real unit: OFF at bottom (6 o'clock), numbers go clockwise: 30,35,40...75,-80
    // Calibrated: 35 (just past OFF, about 5 o'clock)
    // Custom rendering — the real knob has numbers on the faceplate, not tick marks
    {
      const cx = PX + 200, cy = ROW_Y, r = 34;
      // Chrome bezel ring
      s += `<circle cx="${cx}" cy="${cy}" r="${r + 4}" fill="none" stroke="#888" stroke-width="3"/>`;
      s += `<circle cx="${cx}" cy="${cy}" r="${r + 2}" fill="none" stroke="#555" stroke-width="1"/>`;

      // Number positions on faceplate (clockwise from OFF at bottom)
      // OFF=6:00, 30=~5:00, 35=~4:30, 40=~4:00, 45=~3:30 ... 75=~8:00, -80=~7:00
      const gainNums = ['OFF','30','35','40','45','50','55','60','65','70','75','80'];
      const startDeg = 180; // 6 o'clock = 180° in SVG (bottom)
      const endDeg = 180 - 330; // almost full rotation back to ~7 o'clock
      gainNums.forEach((num, i) => {
        const t = i / (gainNums.length - 1);
        // Go clockwise from bottom: 180° → 180° - 330° = -150° (which is 210°)
        // But we want clockwise, so: 180 - t * 330
        const a = (180 + t * 330) * Math.PI / 180;
        const tx = cx + Math.cos(a) * (r + 18);
        const ty = cy + Math.sin(a) * (r + 18);
        const isActive = num === '35';
        // Tick mark
        const tx1 = cx + Math.cos(a) * (r + 8);
        const ty1 = cy + Math.sin(a) * (r + 8);
        const tx2 = cx + Math.cos(a) * (r + 12);
        const ty2 = cy + Math.sin(a) * (r + 12);
        s += `<line x1="${tx1}" y1="${ty1}" x2="${tx2}" y2="${ty2}" stroke="${isActive ? '#fff' : '#ccc'}" stroke-width="1.5"/>`;
        s += `<text x="${tx}" y="${ty + 3}" text-anchor="middle" fill="${isActive ? '#fff' : '#bbb'}" font-family="JetBrains Mono,monospace" font-size="${num === 'OFF' ? 6 : 7}" font-weight="${isActive ? '700' : '400'}">${num === '80' ? '-80' : num}</text>`;
      });

      // Red knob body
      s += `<g class="ctrl" data-note="Preamp gain — large red knob with chrome bezel. Calibrated to 35 for -18dBFS reference tone. Range: OFF → 30 → 80." style="cursor:pointer">`;
      s += `<circle cx="${cx + 1}" cy="${cy + 2}" r="${r}" fill="#080808" opacity="0.4"/>`;
      s += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${RED_KNOB}" stroke="${RED_KNOB_EDGE}" stroke-width="2"/>`;
      // Subtle gradient/sheen
      s += `<circle cx="${cx - 6}" cy="${cy - 6}" r="${r * 0.6}" fill="none" stroke="#a03535" stroke-width="0.5" opacity="0.4"/>`;

      // Pointer — at 35 position (1/11 of range past OFF)
      const pct35 = 1 / 11; // 35 is the second position after OFF
      const pointerAngle = (180 + pct35 * 330) * Math.PI / 180;
      const px = cx + Math.cos(pointerAngle) * (r * 0.78);
      const py = cy + Math.sin(pointerAngle) * (r * 0.78);
      s += `<line x1="${cx}" y1="${cy}" x2="${px}" y2="${py}" stroke="#eee" stroke-width="3" stroke-linecap="round"/>`;

      // Center cap (darker red)
      s += `<circle cx="${cx}" cy="${cy}" r="5" fill="#5a1212" stroke="#7a2222" stroke-width="1"/>`;
      s += `</g>`;

      // Label
      s += `<text x="${cx}" y="${cy + r + 32}" text-anchor="middle" fill="${NEVE_TEXT}" font-family="JetBrains Mono,monospace" font-size="8" font-weight="500" letter-spacing="1">GAIN</text>`;
      s += `<text x="${cx}" y="${cy + r + 44}" text-anchor="middle" fill="${VOCAL_HL}" font-family="JetBrains Mono,monospace" font-size="9" font-weight="600">35</text>`;
    }

    // OUTPUT — Neve stepped attenuator
    // Calibrated: "1 o'clock" position ≈ 65% of range
    // 1073 output is typically a stepped rotary from OFF through various attenuation levels
    const outputPositions = ['OFF','−20','−16','−12','−8','−4','0','+4'];
    s += neveKnob(PX + 330, ROW_Y, 24, 65, 0, 100, 'OUTPUT', '1 o\'clock',
      'silver', outputPositions, 'Output level — stepped Neve attenuator. Calibrated to 1 o\'clock for unity gain through chain.');

    // HIGH EQ — frequency selector + gain
    // 12kHz shelf (fixed on 1073), gain ±16dB
    // Calibrated: FLAT (0dB, center position)
    const hiFreqPositions = ['OFF','12k'];
    s += neveKnob(PX + 430, ROW_Y - 35, 16, 0, 0, 1, 'HF', 'OFF',
      'black', hiFreqPositions, 'High shelf frequency selector — 12kHz or OFF');
    const hiGainPositions = ['-16','-8','0','+8','+16'];
    s += neveKnob(PX + 430, ROW_Y + 40, 18, 0, -16, 16, 'HF GAIN', '0dB',
      'silver', hiGainPositions, 'High shelf gain — ±16dB. Calibrated FLAT (0dB).');

    // MID EQ — frequency selector (6 positions) + gain
    const midFreqPositions = ['.36','.7','1.6','3.2','4.8','7.2'];
    s += neveKnob(PX + 570, ROW_Y - 35, 18, 0, 0, 5, 'MF', 'OFF',
      'black', midFreqPositions, 'Mid peak frequency selector — 360Hz to 7.2kHz (6 positions)');
    const midGainPositions = ['-16','-8','0','+8','+16'];
    s += neveKnob(PX + 570, ROW_Y + 40, 18, 0, -16, 16, 'MF GAIN', '0dB',
      'silver', midGainPositions, 'Mid peak gain — ±16dB. Calibrated FLAT (0dB).');

    // LOW EQ — frequency selector (4 positions) + gain
    const loFreqPositions = ['35','60','110','220'];
    s += neveKnob(PX + 720, ROW_Y - 35, 18, 0, 0, 3, 'LF', 'OFF',
      'black', loFreqPositions, 'Low shelf frequency selector — 35Hz to 220Hz (4 positions)');
    const loGainPositions = ['-16','-8','0','+8','+16'];
    s += neveKnob(PX + 720, ROW_Y + 40, 18, 0, -16, 16, 'LF GAIN', '0dB',
      'silver', loGainPositions, 'Low shelf gain — ±16dB. Calibrated FLAT (0dB).');

    // HPF — stepped rotary
    const hpfPositions = ['OFF','50','80','160','300'];
    s += neveKnob(PX + 870, ROW_Y, 18, 0, 0, 4, 'HPF', 'OFF',
      'black', hpfPositions, 'High-pass filter — 18dB/oct. OFF / 50 / 80 / 160 / 300 Hz');

    // Switches
    s += neveSwitch(PX + 1000, ROW_Y - 40, '48V', false, 'Phantom power — OFF for line level input from Wing Out 1');
    s += neveSwitch(PX + 1050, ROW_Y - 40, 'PAD', false, 'Input pad — -20dB. OFF for normal operation.');
    s += neveSwitch(PX + 1100, ROW_Y - 40, 'POL', false, 'Polarity reverse — OFF (normal phase)');
    s += neveSwitch(PX + 1000, ROW_Y + 30, 'EQL', false, 'EQ bypass — OFF (EQ section bypassed during calibration)');
    s += neveSwitch(PX + 1050, ROW_Y + 30, 'MIC', false, 'Mic/Line selector — LINE mode (receiving from Wing output)');
    s += neveSwitch(PX + 1100, ROW_Y + 30, 'IMP', false, 'Impedance — 1200Ω (default)');

    // ── SIGNAL FLOW ANNOTATION ──
    s += `<text x="${PX + PW/2}" y="${PY + PH - 15}" text-anchor="middle" fill="${NEVE_DIM}" font-family="JetBrains Mono,monospace" font-size="7" letter-spacing="1">SIGNAL: Wing Out 1 → P1 → HA73 A LINE IN → GAIN 35 → OUTPUT → P2 → WA76 A IN</text>`;

    svg.innerHTML = s;

    // ── EVENTS ──
    svg.querySelectorAll('.ctrl').forEach(el => {
      el.addEventListener('mouseenter', () => {
        info.textContent = (el as SVGGElement).dataset.note || '';
        info.style.color = VOCAL_HL;
      });
      el.addEventListener('mouseleave', () => {
        info.textContent = 'Hover over any control';
        info.style.color = '#55554e';
      });
    });
  </script>
</Base>
