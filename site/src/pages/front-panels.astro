---
import Base from '../layouts/Base.astro';
---

<Base title="Front Panels" active="">
  <div style="max-width:1500px;margin:0 auto;padding:0 16px">
    <section class="page-header">
      <h3>Calibrated Settings</h3>
      <h1>Front Panels</h1>
      <p>Outboard gear with dials set to calibrated positions. Reference for every session.</p>
    </section>
  </div>

  <div id="panels">
    <div class="info" id="info">Hover over any control</div>
    <svg id="svg" viewBox="0 0 1400 160" preserveAspectRatio="xMidYMid meet"></svg>
  </div>

  <style>
    #panels { max-width: 1400px; margin: 0 auto; padding: 0 8px 80px; }
    .info {
      font-family: var(--mono); font-size: 11px; color: var(--stone);
      padding: 8px 14px; margin-bottom: 4px;
      background: var(--soot); border: 1px solid var(--smoke); border-radius: 2px;
    }
    #svg { display: block; width: 100%; background: #060608; border: 1px solid #1a1a18; border-radius: 2px; }
  </style>

  <script>
    const svg = document.getElementById('svg')!;
    const info = document.getElementById('info')!;

    // ════════════════════════════════════════════════════════════
    // HERITAGE AUDIO HA73-EQX2 ELITE — Channel A (Vocal)
    //
    // Reference: actual product photos from Sweetwater + user
    // Faceplate: very dark, near-black with subtle navy tint
    // Layout L→R: Logo | "1" | DI jack | GAIN (red, chrome bezel)
    //   | OUTPUT (silver, small) | EQ section (blue freq selectors
    //   + silver gain knobs) | HPF | toggle switches | ELITE SERIES
    //
    // Calibrated: Gain 35, Output 1 o'clock, EQ bypassed
    // ════════════════════════════════════════════════════════════

    const PX = 20, PY = 20;
    const PW = 1360, PH = 110; // 1U height
    const CY = PY + PH / 2; // vertical center

    // Colors matched from photos
    const FP = '#12121a';         // Faceplate — near-black with navy tint
    const FP_EDGE = '#222230';
    const TXT = '#b0b0a8';        // Silver text on faceplate
    const TXT_DIM = '#555560';
    const WHT = '#ddddd0';        // White markings
    const RED_FILL = '#7a1818';   // Red knob body
    const RED_LIGHT = '#9a2828';  // Red knob highlight
    const RED_DARK = '#4a0e0e';   // Red center cap
    const CHROME = '#888890';     // Chrome bezel
    const CHROME_DK = '#555560';
    const BLUE_KNOB = '#2a2a5a';  // Neve-blue EQ frequency selector knobs
    const BLUE_EDGE = '#3a3a6a';
    const BLUE_DOT = '#4a4a8a';   // Blue knob indicator dot
    const SILVER_KNOB = '#606068';// Silver EQ gain / output knobs
    const SILVER_EDGE = '#707078';
    const VOCAL = '#6a9ab8';

    let s = '';

    // ── FACEPLATE ──
    s += `<rect x="${PX}" y="${PY}" width="${PW}" height="${PH}" rx="3" fill="${FP}" stroke="${FP_EDGE}" stroke-width="1.5"/>`;
    // Subtle horizontal brushed texture
    for (let i = 0; i < PH; i += 1) {
      const op = 0.01 + Math.random() * 0.02;
      s += `<line x1="${PX}" y1="${PY + i}" x2="${PX + PW}" y2="${PY + i}" stroke="#181825" stroke-width="0.5" opacity="${op}"/>`;
    }

    // Rack screws — hex style at corners
    [[PX+12, PY+12],[PX+PW-12, PY+12],[PX+12, PY+PH-12],[PX+PW-12, PY+PH-12]].forEach(([sx,sy]) => {
      s += `<circle cx="${sx}" cy="${sy}" r="5" fill="#0a0a10" stroke="#333340" stroke-width="0.8"/>`;
      s += `<line x1="${sx-2}" y1="${sy}" x2="${sx+2}" y2="${sy}" stroke="#333340" stroke-width="0.6"/>`;
      s += `<line x1="${sx}" y1="${sy-2}" x2="${sx}" y2="${sy+2}" stroke="#333340" stroke-width="0.6"/>`;
    });

    // ── HERITAGE AUDIO LOGO ──
    s += `<text x="${PX + 42}" y="${CY - 8}" fill="${TXT}" font-family="DM Serif Display,serif" font-size="11" font-style="italic" opacity="0.8">Heritage</text>`;
    s += `<text x="${PX + 42}" y="${CY + 6}" fill="${TXT}" font-family="DM Serif Display,serif" font-size="8" opacity="0.6">Audio</text>`;

    // Channel number
    s += `<text x="${PX + 115}" y="${CY + 5}" fill="${TXT}" font-family="DM Serif Display,serif" font-size="18" opacity="0.4">1</text>`;

    // ── DI JACK ──
    s += `<g class="ctrl" data-note="Front panel 1/4 inch DI input — instrument level, bypasses rear XLR" style="cursor:pointer">`;
    s += `<circle cx="${PX + 145}" cy="${CY}" r="6" fill="#080810" stroke="#333340" stroke-width="1"/>`;
    s += `<circle cx="${PX + 145}" cy="${CY}" r="2.5" fill="#050508"/>`;
    s += `</g>`;

    // ══════════════════════════════
    // GAIN KNOB — Large red, chrome bezel
    // Numbers on faceplate: OFF, 30, 35, 40...75, -80
    // Calibrated: 35
    // ══════════════════════════════
    {
      const cx = PX + 230, cy = CY, r = 24;
      // Actual layout from photo — clockwise from OFF at bottom:
      // OFF(6:00) → 50(5:15) → 55(4:45) → 60(4:15) → 65(3:45) → 70(3:00)
      // → 75(2:15) → -80(1:00) → 30(12:00) → 35(11:00) → 40(10:00) → 45(9:00?)
      // Then gap back to OFF. High gain on left, low gain on right, -80 near top.
      //
      // In SVG degrees (0=right, 90=down, 180=left, 270=up):
      // OFF = 90° (bottom). Going clockwise = decreasing degrees in SVG.
      // But SVG goes counterclockwise for positive angles.
      // Clockwise in SVG: angle INCREASES (90→180→270→360→90)
      // OFF=90, 50≈120, 55≈150, 60≈170, 65≈195, 70≈220, 75≈248,
      // -80≈278, 30≈305, 35≈330, 40≈352, 45≈18 (past 0/360)

      // Explicit clock positions from the photo:
      // OFF=6:00, 55=7:00, 60=8:00, 65=9:00, 70=10:00, 75=11:00,
      // -80=12:00, 30=1:00, 35=2:00, 40=3:00, 45=4:00, 50=5:00
      // SVG: 0°=3:00, 90°=6:00, 180°=9:00, 270°=12:00
      const gainPositions: {label:string, deg:number}[] = [
        {label:'OFF', deg:90},   // 6:00
        {label:'55',  deg:120},  // 7:00
        {label:'60',  deg:150},  // 8:00
        {label:'65',  deg:180},  // 9:00
        {label:'70',  deg:210},  // 10:00
        {label:'75',  deg:240},  // 11:00
        {label:'-80', deg:270},  // 12:00 (dead top)
        {label:'30',  deg:300},  // 1:00
        {label:'35',  deg:330},  // 2:00
        {label:'40',  deg:360},  // 3:00
        {label:'45',  deg:390},  // 4:00 (=30°)
        {label:'50',  deg:420},  // 5:00 (=60°)
      ];
      const sweepTotal = 330; // 90° to 420°

      // ── WHITE DOTS ── large dot at each number, single small dot between each pair
      const dr = r + 9;
      gainPositions.forEach((pos, i) => {
        const a = pos.deg * Math.PI / 180;
        // Large dot at number position
        s += `<circle cx="${cx + Math.cos(a) * dr}" cy="${cy + Math.sin(a) * dr}" r="2.2" fill="#ffffff"/>`;
        // Small dot halfway to next number (except after last)
        if (i < gainPositions.length - 1) {
          const midDeg = (pos.deg + gainPositions[i + 1].deg) / 2;
          const ma = midDeg * Math.PI / 180;
          s += `<circle cx="${cx + Math.cos(ma) * dr}" cy="${cy + Math.sin(ma) * dr}" r="2" fill="#ffffff"/>`;
        }
      });

      // ── NUMBER LABELS ──
      const numR = r + 22;
      gainPositions.forEach(({label, deg}) => {
        const a = deg * Math.PI / 180;
        const tx = cx + Math.cos(a) * numR;
        const ty = cy + Math.sin(a) * numR;
        s += `<text x="${tx}" y="${ty + 3}" text-anchor="middle" fill="#ffffff" font-family="sans-serif" font-size="${label === 'OFF' ? 7 : 9}" font-weight="700">${label}</text>`;
      });

      // ── CHROME BEZEL ── wide, reflective ring
      s += `<circle cx="${cx}" cy="${cy}" r="${r + 3}" fill="#4a4a4e"/>`;
      s += `<circle cx="${cx}" cy="${cy}" r="${r + 2}" fill="#555558" stroke="#6a6a6e" stroke-width="0.5"/>`;
      // Top highlight on bezel
      s += `<path d="M${cx - r},${cy - 3} A${r},${r} 0 0,1 ${cx + r},${cy - 3}" fill="none" stroke="#999" stroke-width="1" opacity="0.3"/>`;

      // ── RED KNOB ── sculpted with raised center and skirt
      s += `<g class="ctrl" data-note="GAIN — red knob, chrome bezel. OFF → 30 → 35 → ... → 75 → -80. Calibrated to 35." style="cursor:pointer">`;
      // Outer red skirt
      s += `<circle cx="${cx}" cy="${cy}" r="${r - 1}" fill="${RED_FILL}"/>`;
      // Raised inner plateau (darker)
      s += `<circle cx="${cx}" cy="${cy}" r="${r * 0.5}" fill="${RED_DARK}" stroke="${RED_FILL}" stroke-width="0.8"/>`;
      // Subtle sheen
      s += `<ellipse cx="${cx - 3}" cy="${cy - 3}" rx="${r * 0.3}" ry="${r * 0.2}" fill="#aa3333" opacity="0.12"/>`;

      // ── WHITE POINTER LINE ── at 35 = 330° (2:00 position)
      const deg35 = 330;
      const pa35 = deg35 * Math.PI / 180;
      const pxI = cx + Math.cos(pa35) * 4;
      const pyI = cy + Math.sin(pa35) * 4;
      const pxO = cx + Math.cos(pa35) * (r - 2);
      const pyO = cy + Math.sin(pa35) * (r - 2);
      s += `<line x1="${pxI}" y1="${pyI}" x2="${pxO}" y2="${pyO}" stroke="#eeeeee" stroke-width="2.5" stroke-linecap="round"/>`;
      s += `</g>`;
    }

    // ══════════════════════════════
    // OUTPUT — smaller silver stepped knob
    // Calibrated: "1 o'clock" (just past top)
    // ══════════════════════════════
    {
      const cx = PX + 400, cy = CY, r = 16;
      // Tick marks
      for (let i = 0; i < 12; i++) {
        const t = i / 11;
        const a = (90 + t * 300) * Math.PI / 180;
        const t1x = cx + Math.cos(a) * (r + 5);
        const t1y = cy + Math.sin(a) * (r + 5);
        const t2x = cx + Math.cos(a) * (r + 9);
        const t2y = cy + Math.sin(a) * (r + 9);
        s += `<line x1="${t1x}" y1="${t1y}" x2="${t2x}" y2="${t2y}" stroke="${WHT}" stroke-width="0.8" opacity="0.4"/>`;
      }

      s += `<g class="ctrl" data-note="OUTPUT — stepped attenuator. Calibrated to 1 o'clock position." style="cursor:pointer">`;
      // Knurled silver knob
      s += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${SILVER_KNOB}" stroke="${SILVER_EDGE}" stroke-width="1"/>`;
      for (let a = 0; a < 360; a += 10) {
        const rad = a * Math.PI / 180;
        s += `<line x1="${cx + Math.cos(rad)*(r-1)}" y1="${cy + Math.sin(rad)*(r-1)}" x2="${cx + Math.cos(rad)*r}" y2="${cy + Math.sin(rad)*r}" stroke="#7a7a80" stroke-width="0.4"/>`;
      }
      // Pointer — 1 o'clock = 300° in SVG
      const pa = 300 * Math.PI / 180;
      s += `<line x1="${cx}" y1="${cy}" x2="${cx + Math.cos(pa)*r*0.7}" y2="${cy + Math.sin(pa)*r*0.7}" stroke="${WHT}" stroke-width="1.5" stroke-linecap="round"/>`;
      s += `<circle cx="${cx}" cy="${cy}" r="2" fill="${SILVER_EDGE}"/>`;
      s += `</g>`;

      s += `<text x="${cx}" y="${cy + r + 16}" text-anchor="middle" fill="${TXT_DIM}" font-family="JetBrains Mono,monospace" font-size="6" letter-spacing="1">OUTPUT</text>`;
    }

    // ══════════════════════════════
    // EQ SECTION — Neve blue frequency selectors + silver gain
    // Three bands: HIGH (12kHz), MID (7.2k-360Hz), LOW (220-35Hz)
    // Each has a frequency selector (blue) and a gain knob (silver)
    // All bypassed/flat for calibration
    // ══════════════════════════════

    function blueSelector(cx: number, cy: number, r: number, label: string, freqs: string[], note: string) {
      let k = '';
      // Tick marks for positions
      freqs.forEach((f, i) => {
        const t = i / (freqs.length - 1);
        const a = (90 + t * 300) * Math.PI / 180;
        const tx = cx + Math.cos(a) * (r + 10);
        const ty = cy + Math.sin(a) * (r + 10);
        k += `<text x="${tx}" y="${ty + 2}" text-anchor="middle" fill="${TXT_DIM}" font-family="JetBrains Mono,monospace" font-size="4.5" opacity="0.6">${f}</text>`;
      });

      k += `<g class="ctrl" data-note="${note}" style="cursor:pointer">`;
      // Blue knob
      k += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${BLUE_KNOB}" stroke="${BLUE_EDGE}" stroke-width="1.5"/>`;
      // Indicator dot at current position (OFF = bottom)
      const pa = 90 * Math.PI / 180; // OFF at bottom
      k += `<circle cx="${cx + Math.cos(pa)*r*0.6}" cy="${cy + Math.sin(pa)*r*0.6}" r="2" fill="${BLUE_DOT}"/>`;
      k += `</g>`;

      k += `<text x="${cx}" y="${cy + r + 16}" text-anchor="middle" fill="${TXT_DIM}" font-family="JetBrains Mono,monospace" font-size="5.5" letter-spacing="0.5">${label}</text>`;
      return k;
    }

    function silverGain(cx: number, cy: number, r: number, label: string, note: string) {
      let k = '';
      k += `<g class="ctrl" data-note="${note}" style="cursor:pointer">`;
      k += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="${SILVER_KNOB}" stroke="${SILVER_EDGE}" stroke-width="1"/>`;
      // Knurling
      for (let a = 0; a < 360; a += 12) {
        const rad = a * Math.PI / 180;
        k += `<line x1="${cx + Math.cos(rad)*(r-0.5)}" y1="${cy + Math.sin(rad)*(r-0.5)}" x2="${cx + Math.cos(rad)*r}" y2="${cy + Math.sin(rad)*r}" stroke="#7a7a80" stroke-width="0.3"/>`;
      }
      // Pointer at center (0dB / flat)
      const pa = (90 + 0.5 * 300) * Math.PI / 180; // center of range
      k += `<line x1="${cx}" y1="${cy}" x2="${cx + Math.cos(pa)*r*0.65}" y2="${cy + Math.sin(pa)*r*0.65}" stroke="${WHT}" stroke-width="1.2" stroke-linecap="round"/>`;
      k += `<circle cx="${cx}" cy="${cy}" r="1.5" fill="${SILVER_EDGE}"/>`;
      k += `</g>`;
      k += `<text x="${cx}" y="${cy + r + 14}" text-anchor="middle" fill="${TXT_DIM}" font-family="JetBrains Mono,monospace" font-size="5" letter-spacing="0.5">${label}</text>`;
      return k;
    }

    // EQ spacing
    const eqStart = PX + 500;
    const eqGap = 80;

    // HIGH: 12kHz shelf
    s += blueSelector(eqStart, CY - 20, 13, 'HF FREQ', ['OFF','12k'], 'High shelf frequency — 12kHz or OFF. Currently OFF (bypassed).');
    s += silverGain(eqStart, CY + 30, 11, 'HF GAIN', 'High shelf gain ±16dB — at center (0dB, flat).');

    // MID: 360Hz - 7.2kHz peak
    s += blueSelector(eqStart + eqGap, CY - 20, 13, 'MF FREQ', ['.36','.7','1.6','3.2','4.8','7.2'], 'Mid peak frequency — 360Hz to 7.2kHz. Currently OFF.');
    s += silverGain(eqStart + eqGap, CY + 30, 11, 'MF GAIN', 'Mid peak gain ±16dB — at center (0dB, flat).');

    // LOW: 35-220Hz shelf
    s += blueSelector(eqStart + eqGap*2, CY - 20, 13, 'LF FREQ', ['35','60','110','220'], 'Low shelf frequency — 35Hz to 220Hz. Currently OFF.');
    s += silverGain(eqStart + eqGap*2, CY + 30, 11, 'LF GAIN', 'Low shelf gain ±16dB — at center (0dB, flat).');

    // ══════════════════════════════
    // HPF — blue selector
    // ══════════════════════════════
    s += blueSelector(eqStart + eqGap*3 + 20, CY, 13, 'HPF', ['OFF','50','80','160','300'], 'High-pass filter 18dB/oct — OFF / 50 / 80 / 160 / 300 Hz. Currently OFF.');

    // ══════════════════════════════
    // TOGGLE SWITCHES
    // ══════════════════════════════
    const swStart = PX + 960;
    const swGap = 50;

    function toggle(cx: number, cy: number, label: string, active: boolean, note: string, hasLed: boolean = false) {
      let k = '';
      k += `<g class="ctrl" data-note="${note}" style="cursor:pointer">`;
      // Switch body
      k += `<rect x="${cx-5}" y="${cy-10}" width="10" height="20" rx="2" fill="#0a0a10" stroke="#333340" stroke-width="0.8"/>`;
      // Toggle lever
      const ly = active ? cy - 5 : cy + 5;
      k += `<rect x="${cx-3.5}" y="${ly-3}" width="7" height="6" rx="1.5" fill="${active ? '#666' : '#2a2a30'}" stroke="#444" stroke-width="0.3"/>`;
      // LED
      if (hasLed && active) {
        k += `<circle cx="${cx}" cy="${cy - 18}" r="2.5" fill="#cc2222" opacity="0.9"/>`;
        k += `<circle cx="${cx}" cy="${cy - 18}" r="4" fill="#cc2222" opacity="0.1"/>`;
      }
      k += `</g>`;
      k += `<text x="${cx}" y="${cy + 20}" text-anchor="middle" fill="${TXT_DIM}" font-family="JetBrains Mono,monospace" font-size="5" letter-spacing="0.5">${label}</text>`;
      return k;
    }

    s += toggle(swStart, CY - 15, '48V', false, 'Phantom power — OFF (line level from Wing)', true);
    s += toggle(swStart + swGap, CY - 15, 'PAD', false, 'Input pad -20dB — OFF');
    s += toggle(swStart + swGap*2, CY - 15, 'PHASE', false, 'Polarity reverse — OFF (normal)');
    s += toggle(swStart, CY + 35, 'EQ', false, 'EQ bypass — OFF (EQ section bypassed for calibration)');
    s += toggle(swStart + swGap, CY + 35, 'MIC/LINE', false, 'Input selector — LINE mode');
    s += toggle(swStart + swGap*2, CY + 35, 'IMP', false, 'Impedance — 1200 ohm (default)');

    // ── ELITE SERIES TEXT ──
    s += `<text x="${PX + PW - 50}" y="${PY + 35}" text-anchor="end" fill="${TXT}" font-family="JetBrains Mono,monospace" font-size="7" letter-spacing="3" opacity="0.4">ELITE SERIES</text>`;

    // ── CHANNEL / CHAIN INDICATOR ──
    s += `<text x="${PX + PW - 50}" y="${PY + PH - 15}" text-anchor="end" fill="${VOCAL}" font-family="JetBrains Mono,monospace" font-size="7" letter-spacing="1" opacity="0.5">CHANNEL A — VOCAL CHAIN</text>`;
    s += `<text x="${PX + 50}" y="${PY + PH - 15}" fill="${TXT_DIM}" font-family="JetBrains Mono,monospace" font-size="6">Wing Out 1 → P1 → HA73 A → P2 → WA76 A | Gain 35, Output 1 o'clock, EQ bypassed</text>`;

    svg.innerHTML = s;

    // Events
    svg.querySelectorAll('.ctrl').forEach(el => {
      el.addEventListener('mouseenter', () => {
        info.textContent = (el as SVGGElement).dataset.note || '';
        info.style.color = VOCAL;
      });
      el.addEventListener('mouseleave', () => {
        info.textContent = 'Hover over any control';
        info.style.color = '#55554e';
      });
    });
  </script>
</Base>
