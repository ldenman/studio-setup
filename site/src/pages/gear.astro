          <circle cx="418" cy="71" r="4" fill="#5a8a4a"/>
          <text x="412" y="90" font-family="'JetBrains Mono', monospace" font-size="6" fill="#9a9588" text-anchor="middle">EQ IN</text>
          <rect x="440" y="65" width="24" height="12" rx="6" fill="#2a2520" stroke="#68635a" stroke-width="0.8"/>
