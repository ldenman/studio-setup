          <circle cx="130" cy="80" r="9" fill="#2a2520" stroke="#44403a" stroke-width="0.6"/>
          <line x1="130" y1="80" x2="130" y2="70" stroke="#f0ebe0" stroke-width="1" stroke-linecap="round"/>
