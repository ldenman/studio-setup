            <circle cx="40" cy="0" r="6" fill="#2a2520" stroke="#68635a" stroke-width="0.8"/>
            <text x="40" y="2.5" font-family="'JetBrains Mono', monospace" font-size="5" fill="#9a9588" text-anchor="middle">12</text>
