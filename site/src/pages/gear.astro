          <line x1="280" y1="70" x2="275" y2="56" stroke="#f0ebe0" stroke-width="1.2" stroke-linecap="round"/>
          <text x="280" y="97" font-family="'JetBrains Mono', monospace" font-size="7" fill="#9a9588" text-anchor="middle">HI EQ</text>
          <circle cx="340" cy="70" r="16" fill="none" stroke="#d0cabb" stroke-width="1"/>
          <circle cx="340" cy="70" r="12" fill="#2a2520" stroke="#44403a" stroke-width="0.8"/>
