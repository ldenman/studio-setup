</Base>

<style>
  .gear-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-top: 40px;
  }

  .gear-card {
    border: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 280px;
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    cursor: pointer;
  }
  .gear-card:hover { border-color: var(--amber); }

  .gear-panel {
    background: #111110;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }

  .gear-panel svg {
    width: 100%;
    max-height: 180px;
  }

  .gear-info {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
  }

  .gear-type {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-bottom: 10px;
  }

  .gear-info h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 14px;
    line-height: 1.15;
    text-transform: none;
    letter-spacing: normal;
  }

  .gear-info p {
    font-size: 15px;
    color: var(--text);
    margin: 0 0 18px;
    line-height: 1.7;
  }

  .gear-spec {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--amber);
    line-height: 1.9;
  }

  @media (max-width: 768px) {
    .gear-card { grid-template-columns: 1fr; }
    .gear-panel { min-height: 180px; padding: 24px; }
    .gear-info { padding: 28px 20px; }
  }
</style>
