---
import Base from '../layouts/Base.astro';
---

<Base title="Gear" active="gear">
  <section class="page-header">
    <span class="chapter-label">02 — Gear</span>
    <h1>The Chain</h1>
    <p>The outboard rack, the digital mixer, the patchbay, and every piece of hardware that shapes the sound. Permanently wired, normalled and ready.</p>
  </section>

  <div class="vu-bar" style="background: var(--amber)"></div>

  <div class="gear-grid">

    <!-- HA73 -->
