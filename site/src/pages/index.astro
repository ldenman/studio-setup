---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Home" active="home">
  <div class="container">

    <section class="hero">
      <span class="hero__label">Recording Studio</span>
      <h1>Plug in.<br>Hit <em>record</em>.</h1>
      <p>
        Walk in, plug in, and your sound is already running through analog warmth before you play a note. The outboard chain is permanently wired and calibrated &mdash; Neve-style preamp into 1176 into LA-2A. No setup. No patching. Just play.
      </p>
      <svg viewBox="0 0 380 48" xmlns="http://www.w3.org/2000/svg" style="margin: 24px auto 0; max-width: 380px; display: block;" aria-label="Signal flow: Instrument to Outboard to Recorder">
        <rect x="0" y="12" width="100" height="24" rx="2" fill="var(--ink)" />
        <text x="50" y="28" text-anchor="middle" fill="var(--paper)" font-family="var(--font-mono)" font-size="9" letter-spacing="0.5">INSTRUMENT</text>
        <line x1="104" y1="24" x2="130" y2="24" stroke="var(--text-dim)" stroke-width="1.5" />
        <polygon points="130,20 138,24 130,28" fill="var(--text-dim)" />
        <rect x="140" y="12" width="100" height="24" rx="2" fill="var(--amber)" />
        <text x="190" y="28" text-anchor="middle" fill="var(--paper)" font-family="var(--font-mono)" font-size="9" letter-spacing="0.5">OUTBOARD</text>
        <line x1="244" y1="24" x2="270" y2="24" stroke="var(--text-dim)" stroke-width="1.5" />
        <polygon points="270,20 278,24 270,28" fill="var(--text-dim)" />
        <rect x="280" y="12" width="100" height="24" rx="2" fill="var(--ink)" />
        <text x="330" y="28" text-anchor="middle" fill="var(--paper)" font-family="var(--font-mono)" font-size="9" letter-spacing="0.5">RECORDER</text>
      </svg>
    </section>

    <div class="vu-bar"></div>

    <section>
      <h3>How It Works</h3>
      <div class="prose mt-sm">
        <p>
          Every instrument passes through real analog outboard gear on the way to the recorder. Vocals get the Neve-style warmth, 1176 snap, and optical leveling. Guitar gets the same Neve-style color, a second 1176 for punch, and the Distressor for character. The patchbay keeps it all normalled &mdash; the chains are always connected, normalled and ready.
        </p>
        <p>
          The Behringer Wing Rack handles routing and monitoring. Logic Pro records. The Tascam Model 12 mixes with real faders and analog EQ. Three devices, each doing what it does best.
        </p>
      </div>
    </section>

    <section>
      <h3>Gear</h3>
      <div class="grid-auto mt-sm">
        <div class="card">
          <span class="card__label">Console</span>
          <h4>Behringer Wing Rack</h4>
          <p>The digital brain. Routes every signal, handles monitoring, runs effects &mdash; all controllable from the command line.</p>
        </div>
        <div class="card">
          <span class="card__label">Outboard</span>
          <h4>Neve-style &middot; 1176-style &middot; LA-2A-style &middot; Distressor</h4>
          <p>Four pieces of analog processing that give every recording its character before it ever hits the DAW.</p>
        </div>
        <div class="card">
          <span class="card__label">Mixing Console</span>
          <h4>Tascam Model 12</h4>
          <p>Hands-on mixing with real faders and analog EQ. Every stem gets its own channel. Every mix pass is captured.</p>
        </div>
        <div class="card">
          <span class="card__label">Recorder</span>
          <h4>Logic Pro</h4>
          <p>Multi-track recording with unlimited tracks. Also hosts session players for bass, piano, synth, and drums.</p>
        </div>
        <div class="card">
          <span class="card__label">Patchbay</span>
          <h4>Samson S-Patch Plus</h4>
          <p>The outboard chains are always connected. Insert a cable only when you want to reroute something.</p>
        </div>
        <div class="card">
          <span class="card__label">Automation</span>
          <h4>Scripted Everything</h4>
          <p>Channel names, routing, console snapshots &mdash; the entire mixer state is scriptable and repeatable.</p>
        </div>
      </div>
    </section>

    {posts.length > 0 && (
      <section>
        <h3>From the Studio</h3>
        <ul class="post-list mt-sm">
          {posts.map(post => (
            <li class="post-item">
              <span class="post-date">{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <div>
                <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
                <p class="post-desc">{post.data.description}</p>
                {post.data.tags && (
                  <div class="post-tags">
                    {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

  </div>
</Base>
