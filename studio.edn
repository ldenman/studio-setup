 ;; ===== SIGNAL CHAINS =====
 :signal-chains
 {:vocal-outboard
  {:path ["Mic" "Ch1 (LCL/1, GATE)" "Bus 1 (pre-fader 0dB)" "Wing Out 1"
          "P1" "HA73 A" "P2" "WA76 A" "P3" "Opto" "P4"
          "Ch17 (LCL/17, DE-ES)" "Main 1"]}

  :vocal-recording
  {:path ["Ch1 (GATE)" "Bus 1" "outboard (HA73 A -> WA76 A -> Opto)"
          "Ch17 (DE-ES)" "Bus 7 (pre-fader)" "USR/1 (Bus 7L)" "USB 1" "Logic"]
   :note "Records gate + outboard + de-esser. No tape, no reverb."}

  :guitar-electric
  {:path ["DI" "Ch2 (LCL/2)" "Bus 5 (pre-fader)" "FX6/ANGEL or FX1/DELUXE (Bus 5 pre-insert)"
          "Bus 2" "Wing Out 2" "P5" "HA73 B" "P6" "WA76 B" "P7" "Distressor" "P8"
          "Ch18 (LCL/18)" "Main 1"]}

  :guitar-acoustic
  {:path ["DI" "Ch2 (LCL/2)" "Bus 6 (pre-fader)" "FX11/RACKAMP (Bus 6 pre-insert)"
          "Bus 2" "Wing Out 2" "P5" "HA73 B" "P6" "WA76 B" "P7" "Distressor" "P8"
          "Ch18 (LCL/18)" "Main 1"]}

  :guitar-recording-with-amp
  {:path ["Ch2" "Bus 5/6 (amp sim)" "Bus 2" "outboard (HA73 B -> WA76 B -> Distressor)"
          "Ch18" "Bus 8 (pre-fader)" "Wing Out 3" "P9" "Model 12"]
   :note "Bus 5 or 6 unmuted, Ch2->Bus 2 send OFF. Records outboard only."}

  :guitar-recording-clean
  {:path ["Ch2" "Bus 2 (direct send)" "outboard (HA73 B -> WA76 B -> Distressor)"
          "Ch18" "Bus 8 (pre-fader)" "Wing Out 3" "P9" "Model 12"]
   :note "Bus 5+6 muted, Ch2->Bus 2 send ON. Records outboard only."}

  :acoustic-mic-outboard
  {:path ["Condensers" "LCL/3+4" "Ch6" "Bus 6 (pre-fader)"
          "FX11/RACKAMP (Bus 6 pre-insert)" "Bus 2" "outboard chain"]}

  :acoustic-mic-recording
  {:path ["Ch6" "Bus 9 (pre-fader)" "USR/6 (Bus 9L) + USR/7 (Bus 9R)"
          "USB 5/6" "Logic"]
   :note "USB 5/6 OFF by default. Enable when recording condensers."}

  :acoustic-di-bypass
  {:path ["DI" "Ch2" "USR/5 (PRE tap)" "Ch5" "Main 1"]
   :note "Clean DI, no outboard. Muted by default."}

  :reverb
  {:path ["Ch1/Ch2" "Bus 3 send" "FX2/PLATE (Bus 3 pre-insert)" "Bus 3" "Main 1"]}

  :tape-aux-loop
  {:path ["Model 12 AUX 1 Out" "Wing LCL/3" "Ch33"
          "FX13/TAPE (pre-insert)" "FX6/TAPE-DL (post-insert)"
          "USR/3 (POST tap)" "USB 38" "Loopback" "Model 12 Ch 6"]
   :note "Per-channel AUX 1 knobs control send amount. Do not send drums to tape."}

  :reamp
  {:path ["Ch13 (Tape Playback)" "Bus 5 (amp sim)" "Bus 2"
          "outboard" "Ch18" "USR/8" "USB 3" "Loopback" "Model 12 Track 3"]
   :note "MUST disable USB 3 after re-amping."}}

