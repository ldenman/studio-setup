 ;; ===== BUSES =====
 :buses
 {1  {:name "Vocal Send"     :color 2  :out {:wing-out 1 :io-in-idx 1}
      :purpose "Pre-fader send from Ch1 -> vocal outboard chain (P1-P4). Clean signal -- no TAPE."}
  2  {:name "Guitar Send"    :color 9  :out {:wing-out 2 :io-in-idx 3}
      :purpose "Receives from Bus 5 (Electric) and Bus 6 (Acoustic) -> guitar outboard chain (P5-P8). No pre-insert."}
  3  {:name "Reverb"         :color 5  :out :main-only
      :pre-insert {:fx 2 :model "PLATE"}
      :sources ["Bus 1" "Bus 2"]
      :purpose "Shared plate reverb. Assigned to Main 1."}
  4  {:name "Mic Send"       :out {:wing-out 4 :io-in-idx 8}
      :purpose "Condenser mic R send to P10 (R only). Out 3 reassigned to Bus 8 for guitar analog recording."}
  5  {:name "Electric"       :color 9  :out :bus-2-send  :default-mute true
      :pre-insert {:fx 6 :model "ANGEL" :note "lead; FX1 DELUXE available for rhythm"}
      :sources ["Ch2 pre-fader"]
      :purpose "Electric amp sim bus. Muted by default. Sends to Bus 2."}
  6  {:name "Acoustic"       :color 7  :out :bus-2-send
      :pre-insert {:fx 11 :model "RACKAMP" :settings {:pre 7 :buzz 1 :punch 2 :crunch 1 :drive 1 :output 8 :leq 3 :heq 7.5}}
      :sources ["Ch2 pre-fader" "Ch6 pre-fader"]
      :purpose "Acoustic amp sim bus. Active by default. Sends to Bus 2."}
  7  {:name "Vocal Rec"      :color 2  :out :usr-only
      :sources ["Ch17 pre-fader"]
      :purpose "No pre-insert. Feeds USR/1 -> USB 1 -> Logic. Not on main."}
  8  {:name "Guitar Rec"     :color 9  :out {:wing-out 3 :io-in-idx 15}
      :sources ["Ch18 pre-fader"]
      :purpose "No pre-insert. -> P9 (analog to Model 12). Not on main."}
  9  {:name "Mic Rec"        :color 7  :out :usr-only
      :sources ["Ch6 pre-fader"]
      :purpose "No pre-insert. Feeds USR/6+7 -> USB 5/6 -> Logic. OFF by default. Not on main."}
  10 {:name "Rhythm Monitor"  :out :mx3-send
      :pre-insert {:fx 7 :model "RACKAMP"}
      :sources ["Ch26" "Ch18"]
      :purpose "Rhythm guitar amp sim for mixing. Sends to MX3. Not on main."}
  11 {:name "Lead Monitor"    :out :mx4-send
      :pre-insert {:fx 12 :model "ANGEL"}
      :sources ["Ch27" "Ch18"]
      :purpose "Lead guitar amp sim for mixing. Sends to MX4. Not on main."}
  12 {:status :open} 13 {:status :open} 14 {:status :open}
  15 {:status :open} 16 {:status :open}}

