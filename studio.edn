  35      {:source "MX4 (Mix Lead)"           :dest "M12 Ch 3"   :default :on}
  36      {:source "MX5 (Mix Overdub)"        :dest "M12 Ch 4"   :default :on}
  37      {:source "MX6 (Mix Bass)"           :dest "M12 Ch 5"   :default :on}
