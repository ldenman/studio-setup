 ;; ===== USR ROUTING (Virtual Patchbay) =====
 ;; USR `in` uses simple bus/channel numbering (Bus 7 = in=7), NOT stereo indices.
 :usr
 {1 {:name "Vocal Dry"      :grp "BUS" :in 7  :tap "PRE" :lr "L"    :usb-out 1  :default :on
     :purpose "Clean outboard vocal for recording (no tape)"}
  2 {:name "(free)"          :note "Freed -- guitar recording now uses analog (Out 3 -> P9)"}
  3 {:name "Tape Return"     :grp "CH"  :in 33 :tap "POST" :lr "L+R" :usb-out 38 :default :on
     :purpose "Tape-processed signal (TAPE + TAPE-DL) from M12 AUX 1 loop -> M12 Ch 6"}
  4 {:name "(free)"          :status :open}
  5 {:name "Gtr Acoustic DI" :grp "CH"  :in 2  :tap "PRE"  :lr "L+R"
     :purpose "Clean DI tap for Ch5; bypasses outboard"}
  6 {:name "Mic Dry L"       :grp "BUS" :in 9  :tap "PRE"  :lr "L"   :usb-out 5  :default :off
     :purpose "Condenser mic L recording (enable when recording condensers)"}
  7 {:name "Mic Dry R"       :grp "BUS" :in 9  :tap "PRE"  :lr "R"   :usb-out 6  :default :off
     :purpose "Condenser mic R recording (enable when recording condensers)"}
  8 {:name "Re-amp Out"      :grp "CH"  :in 18 :tap "PRE"  :lr "L"   :usb-out 3  :default :off
     :purpose "Guitar Processed output for re-amping. MUST disable USB 3 after use."}}

