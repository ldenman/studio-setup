;; studio.edn — Single source of truth for all studio configuration
;; All structured data lives here. Docs reference this file for config.
;; Last updated: 2026-03-29

{:studio
 {:name "Lake's Studio"
  :priorities [:zero-latency :zero-phase :zero-noise]}

 :network
 {:wing {:ip "192.168.2.2" :osc-port 2223 :wapi-port 2222}
  :wing-sync {:path "~/src/wing-sync"}}

 :gear
 {:wing {:model "Behringer Wing Rack" :role :mixer-fx-monitor}
  :model-12 {:model "Tascam Model 12" :role :mixing-console}
  :recorder {:app :logic-pro :role :primary-recorder}
  :outboard
  {:ha73 {:model "HA73-EQX2" :type "Neve 1073 preamp/EQ clone" :channels :dual}
   :wa76 {:model "WA76-D2 Black" :type "1176 compressor clone" :channels :dual :features [:parallel-comp :stereo-link]}
   :distressor {:model "Empirical Labs Distressor" :type "compressor" :channels :single}
   :opto {:model "Audioscape Opto" :type "LA-2A compressor clone" :channels :single}}
  :patchbay {:model "Samson S-Patch Plus" :points 48 :mode :normalled :connector "TRS"}
  :speakers {:output [:wing-out-7 :wing-out-8] :source "MX1 (MON.PH)"}}

 :colors
 {1 "Gray Blue" 2 "Medium Blue" 3 "Dark Blue" 4 "Turquoise"
  5 "Green" 6 "Olive Green" 7 "Yellow" 8 "Orange"
  9 "Red" 10 "Coral" 11 "Pink" 12 "Mauve"}

